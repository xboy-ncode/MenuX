---
import Layout from "../layouts/main.astro";
import { client } from "../lib/sanity";
import { urlFor } from "../lib/sanity";
import { ProductCard } from "../components/menu/ProductCard";
import { CartDialog } from "../components/cart/CartDialog";
import type { Product } from "../types";

// 1. Fetch de datos
const products = await client.fetch<Product[]>(
  `*[_type == "product"] | order(category asc)`
);
// 2. Agrupar por categorías
const grouped = products.reduce(
  (acc, product) => {
    const cat = product.category || "Varios";
    if (!acc[cat]) acc[cat] = [];
    acc[cat].push(product);
    return acc;
  },
  {} as Record<string, Product[]>,
);
---

<Layout title="Perros y Hamburguesas Premium | Menú">
  {/* Fondo Decorativo */}
  <div
    class="fixed inset-0 z-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-orange-900/20 via-slate-950 to-slate-950 pointer-events-none"
  >
  </div>

  <div class="relative z-10 container mx-auto px-4 py-8 pb-32">
    {/* Header */}
    <header class="mb-12 text-center">
      <h1
        class="text-4xl md:text-6xl font-black text-transparent bg-clip-text bg-gradient-to-r from-orange-400 to-red-600 uppercase italic tracking-tighter drop-shadow-sm"
      >
        Perros y Hamburguesas Premium
      </h1>
      <p
        class="text-slate-400 mt-2 font-medium tracking-widest uppercase text-sm"
      >
        Fuego, Sabor & Rapidez
      </p>
    </header>

    {/* Listado de Productos */}
    <div class="space-y-12">
      {
        Object.entries(grouped).map(([category, items]) => (
          <section key={category}>
            <div class="flex items-center gap-4 mb-6">
              <h2 class="text-2xl font-bold text-orange-500 uppercase border-l-4 border-red-600 pl-4">
                {category}
              </h2>
              <div class="h-px bg-slate-800 flex-grow" />
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
              {items.map((product) => (
                <ProductCard
                  client:visible
                  key={product._id}
                  product={product}
                />
              ))}
            </div>
          </section>
        ))
      }
    </div>
  </div>

  {/* Carrito Flotante (Client Load para que sea interactivo inmediatamente) */}
  <CartDialog client:load />
</Layout>
